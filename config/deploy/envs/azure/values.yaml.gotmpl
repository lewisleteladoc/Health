            port: 9000


  ingressinternal:
    enabled: true
    rules:
      - host: "{{ requiredEnv "IMAGE_NAME" }}-{{ requiredEnv "NAMESPACE" }}.private.{{ requiredEnv "DOMAIN" }}"
        paths:
          - path: /
            pathType: Prefix
            port: 9000
      - host: "{{ requiredEnv "IMAGE_NAME" }}-oneapp-{{ requiredEnv "NAMESPACE" }}.private.{{ requiredEnv "DOMAIN" }}"
        paths:
          - path: /
            pathType: Prefix
            port: 9000

  ingressinternal:
    enabled: true
    rules:
      - host: "{{ requiredEnv "IMAGE_NAME" }}-{{ requiredEnv "NAMESPACE" }}.private.{{ requiredEnv "DOMAIN" }}"
        paths:
          - path: /
            pathType: Prefix
            port: 9000
      - host: "{{ requiredEnv "IMAGE_NAME" }}-oneapp-{{ requiredEnv "NAMESPACE" }}.private.{{ requiredEnv "DOMAIN" }}"
